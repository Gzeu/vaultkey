# VaultKey — Non-secret configuration
# Copy to .env and adjust as needed.
# NEVER put API keys, passwords, or secrets here.

# ── Paths ─────────────────────────────────────────────────────────────────────

# Path to wallet encrypted file (default: wallet.enc)
VAULTKEY_WALLET_PATH=wallet.enc

# Backup directory (default: backups)
VAULTKEY_BACKUP_DIR=backups

# Audit log path (default: audit.log)
VAULTKEY_AUDIT_LOG_PATH=audit.log

# ── Session ───────────────────────────────────────────────────────────────────

# Auto-lock after N minutes of inactivity (default: 15, range: 1–1440)
# Set to 60 for a comfortable working session.
VAULTKEY_SESSION_TIMEOUT_MINUTES=60

# Max consecutive failed unlock attempts before hard lockout (default: 5, range: 1–50)
VAULTKEY_MAX_FAILED_ATTEMPTS=5

# Base delay in seconds for exponential backoff: 2^(attempt-1) capped at 60s
# (default: 2, range: 1–30)
VAULTKEY_LOCKOUT_BASE_DELAY=2

# Hard lockout duration in seconds after MAX_FAILED_ATTEMPTS (default: 60, range: 10–3600)
VAULTKEY_HARD_LOCKOUT_SECONDS=60

# ── Clipboard ─────────────────────────────────────────────────────────────────

# Clipboard auto-clear delay in seconds (default: 30)
VAULTKEY_CLIPBOARD_CLEAR_SECONDS=30

# ── Backup ────────────────────────────────────────────────────────────────────

# Max backup files to retain (default: 20)
VAULTKEY_MAX_BACKUPS=20
