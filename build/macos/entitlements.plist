<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: allow JIT (needed by some CFFI paths) -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>

    <!-- Allow unsigned executable memory (CFFI may need this) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>

    <!-- Disable library validation to allow bundled .so files -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network client access (for webhooks / httpx) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Keychain access (for future biometric / Keychain integration) -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)io.vaultkey.app</string>
    </array>

    <!-- Future: Touch ID / LocalAuthentication -->
    <!-- Uncomment when biometric auth is implemented:
    <key>com.apple.security.personal-information.location</key>
    <false/>
    -->
</dict>
</plist>
