<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime entitlements for VaultKey macOS -->

    <!-- Allow JIT compilation (needed by some Python C extensions) -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>

    <!-- Allow unsigned executable memory (Python requires this) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation to allow third-party dylibs (cryptography, argon2) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Access to user-selected files (for import/export) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Network client access (for webhooks) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Keychain access (for future biometric/credential storage) -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)io.vaultkey.app</string>
    </array>
</dict>
</plist>
